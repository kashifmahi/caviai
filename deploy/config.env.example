# CAVI deploy config — copy this file to "config.env" and fill in your values.
#   cp config.env.example config.env  &&  nano config.env
# config.env is gitignored, so your secrets are never pushed and git pull never conflicts.

DOMAIN="yourdomain.com"                       # your domain (without https://)
REPO_URL="https://github.com/USER/REPO.git"   # your GitHub repo URL
ADMIN_EMAIL="admin@yourdomain.com"            # CAVI superadmin LOGIN email
ADMIN_PASSWORD="ChangeThisStrongPassword"     # CAVI superadmin LOGIN password
SUPPORT_EMAIL="support@cavi.solutions"        # shown to flagged users to contact
SMTP_HOST="smtp.hostinger.com"                # SMTP server for outgoing email
SMTP_PORT="465"                               # 465 (SSL) recommended
SMTP_USER="support@cavi.solutions"            # mailbox login (full email)
SMTP_PASS="ChangeThisMailboxPassword"         # mailbox password
SMTP_FROM="support@cavi.solutions"            # From address on emails
ADMIN_NOTIFY_EMAIL="kashifmahi271@gmail.com"  # gets deposit/withdrawal alerts
REOWN_PROJECT_ID="your-walletconnect-project-id"  # from https://cloud.reown.com
LETSENCRYPT_EMAIL="you@email.com"             # email for SSL renewal notices
